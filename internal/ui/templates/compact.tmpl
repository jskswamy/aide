{{- boldGreen "🔧 aide" -}}
{{- if .ContextName}} · {{contextIconDisplay .}}{{end}} ({{agentIconPrefix .}}{{agentDisplay .}})
{{- if .MatchReason}}
   📁 {{.MatchReason}}
{{- end}}
{{- if .SecretName}}
   🔐 secret: {{secretDisplay .}}
{{- end}}
{{- if hasTrust .}}

{{red (trustStatusLine .)}}
{{- with trustWantsLine .}}
   {{yellow .}}
   {{dim "aide trust · aide deny · aide --ignore-project-config"}}
{{- end}}
{{- end}}
{{- $lines := envItemLines . -}}
{{- if $lines}}

   📦 env: {{index $lines 0}}
{{- range slice $lines 1}}
           {{.}}
{{- end}}
{{- end}}
{{- if sandboxDisabled .}}

   🛡 sandbox: disabled
{{- else if hasCapOrExtra .}}

   🛡 sandbox: {{isolationTierLabel .}}, network {{networkLabel .}}
{{- with sandboxPorts .}}
   🛡 ports: {{.}}
{{- end}}
{{- range .Capabilities}}
     {{boldGreen "✓"}} {{printf "%-10s" (print .Name (variantSuffix .Variants))}}{{freshMarker .FreshGrant}} {{capPaths .}}
{{- if and .Source (ne .Source "context config")}}  {{dim (printf "← %s" .Source)}}{{end}}
{{- end}}
{{- if .ExtraWritable}}
     {{yellow "⊕"}} writable:  {{join .ExtraWritable ", "}}
{{- end}}
{{- if .ExtraReadable}}
     {{yellow "⊕"}} readable:  {{truncate .ExtraReadable 3}}
{{- end}}
{{- if .ExtraDenied}}
     {{red "⊘"}} denied:    {{join .ExtraDenied ", "}}
{{- end}}
{{- range .DisabledCaps}}
     {{dim "○"}} {{printf "%-10s" .Name}} disabled for this session  ← --without
{{- end}}
{{- range .SuggestedCaps}}
     {{dim "○"}} {{printf "%-10s" .Name}} {{capPaths .}}  {{dim (printf "detected%s — aide --with %s" (suggestedEvidence .DetectionHint) .Name)}}
{{- end}}
{{- range .NeverAllow}}
     {{red "✗"}} denied    {{.}} (never-allow)
{{- end}}
{{- range .CompWarnings}}
     {{yellow "⚠"}} {{.}}
{{- end}}
{{- else}}

   🛡 sandbox: {{isolationTierLabel .}}, network {{networkLabel .}}, code-only
{{- with sandboxPorts .}}
   🛡 ports: {{.}}
{{- end}}
{{- end}}
{{- range .Warnings}}
     {{yellow "⚠"}} {{.}}
{{- end}}
{{- if .Sandbox}}
{{- range .Sandbox.Hints}}
     {{yellow "💡"}} {{.}}
{{- end}}
{{- end}}
{{- if .AutoApprove}}
   {{red "⚡ AUTO-APPROVE — all agent actions execute without confirmation"}}
{{- end}}
